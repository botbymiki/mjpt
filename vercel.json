{
  "version": 2,
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/*.js",  "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/feed",     "dest": "/public/feed.html" },
    { "src": "/settings", "dest": "/public/settings.html" },
    { "src": "/css/(.*)", "dest": "/public/css/$1" },
    { "src": "/js/(.*)",  "dest": "/public/js/$1" },
    { "src": "/",         "dest": "/public/index.html" }
  ]
}
