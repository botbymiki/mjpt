{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*",  "destination": "/api/:path*" },
    { "source": "/feed",        "destination": "/public/feed.html" },
    { "source": "/settings",    "destination": "/public/settings.html" },
    { "source": "/css/:path*",  "destination": "/public/css/:path*" },
    { "source": "/js/:path*",   "destination": "/public/js/:path*" },
    { "source": "/assets/:path*", "destination": "/public/assets/:path*" },
    { "source": "/",            "destination": "/public/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" }
      ]
    }
  ]
}
